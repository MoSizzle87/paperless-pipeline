# ─────────────────────────────────────────────
# filethat — .gitignore
# ─────────────────────────────────────────────

# Environment — NEVER commit
.env
.env.local
.env.*.local

# Paperless data — NEVER commit
data/

# Runtime logs
logs/*.jsonl
logs/*.jsonl.*
logs/*.log
!logs/.gitkeep

# Personal referential overrides — NEVER commit
config/**/correspondents.local.yaml

# Python
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
*.egg-info/
.eggs/
build/
dist/

# Python virtual environments
.venv/
venv/
env/

# Python tool caches
.ruff_cache/
.mypy_cache/
.pytest_cache/
.coverage
htmlcov/

# macOS
.DS_Store
.AppleDouble
.LSOverride
._*

# Editors
.vscode/
.idea/
*.swp
*.swo
*~

# uv
# uv.lock IS committed (pins versions), do NOT ignore
.uv/
