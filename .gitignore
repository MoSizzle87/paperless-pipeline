# ─────────────────────────────────────────────
# paperless-pipeline — .gitignore
# ─────────────────────────────────────────────

# Environnement — JAMAIS commité
.env
.env.local
.env.*.local

# Données Paperless — JAMAIS commitées
data/

# Logs runtime
logs/*.jsonl
logs/*.jsonl.*
logs/*.log
!logs/.gitkeep

# Python
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
*.egg-info/
.eggs/
build/
dist/

# Environnements virtuels Python (dev local hors Docker)
.venv/
venv/
env/

# Caches outils Python
.ruff_cache/
.mypy_cache/
.pytest_cache/
.coverage
htmlcov/

# macOS
.DS_Store
.AppleDouble
.LSOverride
._*

# Éditeurs
.vscode/
.idea/
*.swp
*.swo
*~

# uv
# uv.lock EST commité (fige les versions), ne PAS l'ignorer
.uv/
